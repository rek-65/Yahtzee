    <!--
     Defines the resource path to the in-app instructions document.

     The path follows the Compose Multiplatform resources "files" convention:
     - All non-compiled assets are stored under:
         composeResources/files/
     - The value here must be a relative path from that root.

     Naming convention:
     - instructions_<language>.md
     - Example: instructions_en.md

     This flat structure avoids nested directories and ensures that:
     - Language selection remains a single-point change
     - Resource loading stays simple and predictable
     - No additional path logic is required in Kotlin code

     To support another language:
     1. Add a new file following the same naming pattern:
        files/instructions_es.md
     2. Update only this string resource to point to the desired language.
    -->
    <string name="instructions_document_path">files/instructions_en.md</string>
</resources>